{
  "schema_version": "coding_agent_source_intake_signoff_cases.v1",
  "purpose": "Final sign-off matrix for source-intake LLM plus deterministic source resolver integration.",
  "execution_contract": {
    "real_llm_intake_required": true,
    "deterministic_resolver_required": true,
    "run_cases_one_at_a_time": true,
    "trace_artifact_required": true,
    "unsupported_hosts_must_not_be_probed": true,
    "supported_provider_access_may_be_stubbed_only_when_the_case_declares_access_stub": true
  },
  "anti_cheat_contract": {
    "fixture_is_review_metadata_only": true,
    "do_not_inject_into_prompts": [
      "case_id",
      "category",
      "coverage_tags",
      "expected",
      "forbidden_failure_modes"
    ],
    "deterministic_code_must_not": [
      "branch on case_id",
      "branch on fixture category",
      "rewrite LLM source roles from fixture expectations",
      "promote deterministic visible spans into semantic roles",
      "substitute a question-text source after an explicit source field fails",
      "probe unsupported hosts to discover whether they redirect"
    ],
    "allowed_deterministic_checks": [
      "schema validation",
      "literal preservation for source text present in task_text or trusted request fields",
      "provider grammar validation",
      "local path trust validation",
      "source cardinality validation",
      "public status and limitation mapping",
      "trace and error sanitization"
    ]
  },
