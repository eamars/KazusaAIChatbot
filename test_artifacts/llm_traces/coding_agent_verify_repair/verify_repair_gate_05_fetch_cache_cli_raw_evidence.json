        "diff_text": "diff --git a/inventory_sync/fetch.py b/inventory_sync/fetch.py\n--- a/inventory_sync/fetch.py\n+++ b/inventory_sync/fetch.py\n@@ -1,6 +1,23 @@\n from urllib.request import urlopen\n+from pathlib import Path\n+import hashlib\n \n \n-def fetch_page(url):\n-    with urlopen(url) as response:\n-        return response.read().decode('utf-8')\n+def fetch_page(url, *, timeout=10, cache_dir=None, refresh_cache=False):\n+    if cache_dir and not refresh_cache:\n+        cache_path = Path(cache_dir) / f\"{hashlib.sha256(url.encode()).hexdigest()}.cache\"\n+        if cache_path.exists():\n+            return cache_path.read_text(encoding='utf-8')\n+\n+    try:\n+        with urlopen(url, timeout=timeout) as response:\n+            content = response.read().decode('utf-8')\n+    except TimeoutError:\n+        with urlopen(url, timeout=timeout) as response:\n+            content = response.read().decode('utf-8')\n+\n+    if cache_dir:\n+        cache_path = Path(cache_dir) / f\"{hashlib.sha256(url.encode()).hexdigest()}.cache\"\n+        cache_path.write_text(content, encoding='utf-8')\n+\n+    return content\n",
